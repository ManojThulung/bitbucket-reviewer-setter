{
    "manifest_version": 3,
    "name": "Bitbucket Reviwer Setter",
    "version": "1.0",
    "description": "Quickly swap the default Bitbucket PR review to your custome choice.",
    "permissions": ["storage", "activeTab", "scripting"],
    "host_permissions": [
        "https://bitbucket.org/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Set Reviewer"
    }
}